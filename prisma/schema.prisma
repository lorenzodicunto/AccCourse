generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Multi-Tenant RBAC Models ─────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN // Full platform access
  ADMIN       // Tenant-level admin (manages users and settings within their tenant)
  EDITOR      // Can create and edit courses
  REVIEWER    // Can only view and comment on shared courses
  VIEWER      // Read-only access to published courses
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  users     User[]
  courses   Course[]
  assets    Asset[]
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         UserRole @default(EDITOR)
  tenantId     String?
  tenant       Tenant?  @relation(fields: [tenantId], references: [id])
  courses      Course[]
  assets       Asset[]    @relation("uploadedAssets")
  createdAt    DateTime @default(now())

  @@index([tenantId])
}

model Course {
  id          String   @id @default(cuid())
  title       String
  description String   @default("")
  thumbnail   String   @default("")
  courseData   Json     @default("{}")
  tenantId    String?
  authorId    String
  tenant      Tenant?  @relation(fields: [tenantId], references: [id])
  author      User     @relation(fields: [authorId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@index([authorId])
}

// ─── Review Portal Models ─────────────────────────────────────────────────────

model SharedCourse {
  id         String    @id @default(cuid())
  title      String
  courseData  Json
  createdAt  DateTime  @default(now())
  comments   Comment[]
}

model Reviewer {
  id        String    @id @default(cuid())
  name      String
  email     String
  createdAt DateTime  @default(now())
  comments  Comment[]
}

model Comment {
  id             String       @id @default(cuid())
  text           String
  slideId        String
  sharedCourseId String
  reviewerId     String
  createdAt      DateTime     @default(now())
  sharedCourse   SharedCourse @relation(fields: [sharedCourseId], references: [id], onDelete: Cascade)
  reviewer       Reviewer     @relation(fields: [reviewerId], references: [id], onDelete: Cascade)

  @@index([sharedCourseId])
  @@index([reviewerId])
}

// ─── Asset Library ────────────────────────────────────────────────────────────

model Asset {
  id         String   @id @default(cuid())
  name       String
  url        String
  type       String   // "image", "video", "document", "audio"
  size       Int      @default(0)
  tenantId   String?
  uploadedBy String
  tenant     Tenant?  @relation(fields: [tenantId], references: [id])
  uploader   User     @relation("uploadedAssets", fields: [uploadedBy], references: [id])
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([uploadedBy])
}
