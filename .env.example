# ─── Database (PostgreSQL — production / Docker) ─────────────────────
DATABASE_URL="postgresql://acccourse:CHANGE_ME@db:5432/acccourse"
POSTGRES_DB=acccourse
POSTGRES_USER=acccourse
POSTGRES_PASSWORD=CHANGE_ME

# ─── Database (SQLite — local development) ───────────────────────────
# DATABASE_URL="file:./prisma/dev.db"

# ─── NextAuth ────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 64
NEXTAUTH_SECRET="CHANGE_ME_generate_with_openssl_rand_base64_64"
NEXTAUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST=true

# ─── AI (Optional — GPT-4o features) ────────────────────────────────
OPENAI_API_KEY="sk-..."

# ─── Admin Seed ──────────────────────────────────────────────────────
# Password for the default admin user created on first boot.
# Change immediately after setup!
ADMIN_DEFAULT_PASSWORD="CHANGE_ME"
